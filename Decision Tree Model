#  Decision Tree
import pandas as pd
import numpy as np
import seaborn as sns
from sklearn import tree
import matplotlib.pyplot as plt
from sklearn.tree import plot_tree
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import (accuracy_score, precision_score, recall_score, f1_score, confusion_matrix)

# Load Data:
df = pd.read_csv('/content/alzheimers_disease_data.csv')

# Drop unnecessary columns (Patient ID and Doctor In Charge b/c irrelevant to diagnosis):
df = df.drop(columns=["PatientID", "DoctorInCharge"])

# Separate train_test_split
X = df.drop(columns=["Diagnosis"])
y = df["Diagnosis"]

# Metrices to store scores:
accuracies = []
precisions = []
recalls = []
f1_scores = []
conf_matrices = []

# Run 100 iterations:
for i in range(100):

  # 80/20 Split:
  X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, random_state=i)

  # Scale/fit data:
  scaler = StandardScaler()
  X_train = scaler.fit_transform(X_train)
  X_test = scaler.transform(X_test)

  # MLM:
  model = tree.DecisionTreeClassifier(criterion = 'entropy', min_samples_split = 26 , max_depth = 5, random_state = i)
  model.fit(X_train, y_train)

  # Predict:
  y_pred = model.predict(X_test)

  # Metrics & Scores:
  accuracies.append(accuracy_score(y_test, y_pred))
  precisions.append(precision_score(y_test, y_pred))
  recalls.append(recall_score(y_test, y_pred))
  f1_scores.append(f1_score(y_test, y_pred))

  # C-Matrix for this run:
  conf_matrices.append(confusion_matrix(y_test, y_pred))

# Convert confusion matrices to array for averaging:
conf_matrices = np.array(conf_matrices)

# Calculate average:
avg_conf_matrix = np.mean(conf_matrices, axis=0)

#  Decision Tree
random_instance = 42
X_train_dt, X_test_dt, y_train_dt, y_test_dt = train_test_split(X, y, test_size = 0.2, random_state = random_instance)
dt_model = tree.DecisionTreeClassifier(criterion = 'entropy', min_samples_split = 26 , max_depth = 5, random_state = random_instance)
dt_model.fit(X_train_dt, y_train_dt)

# plot Decision Tree
plt.figure(figsize = (30,15), dpi=300)
plot_tree(dt_model, filled = True, feature_names = X.columns, class_names = ["No Disease", "Disease"], rounded = True)
plt.show()

# Report the model's performance on the test dataset, including the overall accuracy, precision, recall, and F1 scores for each category.

y_pred = dt_model.predict(X_test_dt)

#comput correlation heat map
cm = confusion_matrix(y_test_dt, y_pred)
plt.figure(figsize=(6,5))
sns.heatmap(cm, annot = True, fmt = 'd', cmap = 'Blues', xticklabels = ["False", "True"], yticklabels=["False", "True"])

plt.xlabel('Predicted')
plt.ylabel('Actual')
plt.title('Confusion Matrix')
